              <zone h='12609' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99034' x='483' y='6617' />
              <zone h='79775' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99034' x='483' y='19226'>
                <flipboard active-id='6' nav-type='caption' show-nav-arrows='true'>
                  <story-points>
                    <story-point caption='&quot;This map shows the global Economic Freedom Scores for the year 2022. Green regions indicate countries with high economic freedom, while red regions represent those with low scores.&quot;' captured-sheet='2022 Economic Freedom Score ' id='1'>
                      <capturedDeltas>
                        <worksheet name='2022 Economic Freedom Score '>
                          <style delta-type='added'>
                            <style-rule element='axis'>
                              <encoding attr='space' class='0' field='[federated.1jdmljq0n471by1ejmoni1l42c3n].[Latitude (generated)]' field-type='quantitative' max='13546580.708985049' min='-10997984.734586652' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                              <encoding attr='space' class='0' field='[federated.1jdmljq0n471by1ejmoni1l42c3n].[Longitude (generated)]' field-type='quantitative' max='30380116.078292489' min='-25773061.934345342' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                            </style-rule>
                          </style>
                        </worksheet>
                      </capturedDeltas>
                    </story-point>
                    <story-point caption='&quot;This map represents the top 40 ranked countries in the Economic Freedom Index. Red indicates countries with lower world rankings, while blue represents those with higher rankings. Poland holds one of the highest world ranks.&quot;' captured-sheet='Top 40 ranking countries in the Index' id='3' />
                    <story-point caption='&quot;This map highlights the countries with the lowest rankings in the Economic Freedom Index. The intensity of the color indicates the severity of their low rankings.&quot;' captured-sheet='Bottom Ranking Countries in the Index' id='4' />
                    <story-point caption='&quot;This bar chart illustrates the Economic Freedom Index scores in relation to unemployment rates. Armenia has the highest unemployment rate, while Burma records the lowest.&quot;' captured-sheet='Index Score Based on Unemployment Rate' id='5' />
                    <story-point caption='&quot;This tree map illustrates the Economic Freedom Index scores based on financial freedom. Different regions exhibit varying levels of financial freedom.&quot;' captured-sheet='Index Score Based on Financial Freedom' id='6' />
                    <story-point caption=' &quot;This horizontal bar chart shows the Economic Freedom Index scores in relation to population size. Brazil has the highest population among the countries shown, while Bahrain has the lowest.&quot;' captured-sheet='Index score Based on Population' id='7' />
                    <story-point caption='&quot;This Gantt chart displays the Economic Freedom Index scores based on the 5-year GDP growth rate of various countries.&quot;' captured-sheet='Index Score based on 5 Year GDP Growth Rate' id='8' />
                    <story-point caption='&quot;This area chart illustrates the impact of inflation on a country&apos;s overall standing in the Economic Freedom Index. As shown, Venezuela experiences the highest inflation rate in the world.&quot;' captured-sheet='Inflation Rate in Different Countries' id='9' />
                    <story-point caption='&quot;This line graph demonstrates the correlation between inflation and unemployment. The graph indicates a close relationship between the two variables.&quot;' captured-sheet='Correlation between Inflation and Unemployment' id='10' />
                    <story-point caption='&quot;This line graph illustrates the correlation between GDP per capita (PPP) and a country&apos;s level of monetary freedom.&quot;' captured-sheet='Correlation Between GDP(PPP) and Monetary Freedom' id='11' />
                    <story-point caption='This chart demonstrates the GDP growth rate of different countries, and the effect of it on their final rank' captured-sheet='Top 40 Countries by GDP Growth Rate' id='12' />
                  </story-points>
                </flipboard>
